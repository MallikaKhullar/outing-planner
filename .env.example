# Outing Planner - Environment Variables
# Copy to .env and fill in your API keys

# Claude AI (Anthropic) - for intent parsing and summaries
ANTHROPIC_API_KEY=

# Google Places API - for place search
GOOGLE_PLACES_API_KEY=

# Yelp Fusion API - for place search
YELP_API_KEY=

# Foursquare Places API - for place search
FOURSQUARE_API_KEY=

# OpenWeather API - for weather data
OPENWEATHER_API_KEY=

# Mapbox - for interactive map display
MAPBOX_TOKEN=

# Server port (default: 8080)
PORT=8080
